{
  "name": "mfh-tools-pro",
  "version": "4.0.0",
  "description": "🔥 MFH TOOLS PRO - Suite de Ciberseguridad Mexicana | Escáner UDP/TCP, RSA/AES, OSINT, Rainbow Tables, WHOIS API, PWA, IA Asistente",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-db.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node run_all_tests.js",
    "test:integration": "node scripts/test-integration.js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "cleancss -o public/css/style.min.css public/css/style.css",
    "build:js": "uglifyjs public/js/*.js -o public/js/app.min.js",
    "docker:build": "docker build -t mfh-tools-pro .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "lint": "eslint .",
    "format": "prettier --write .",
    "security:audit": "npm audit && npm run snyk-test",
    "snyk-test": "snyk test",
    "backup:db": "node scripts/backup-db.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs mfh-tools-pro"
  },
  "keywords": [
    "cybersecurity",
    "port-scanner",
    "network-tools",
    "security-audit",
    "penetration-testing",
    "osint",
    "encryption",
    "whois",
    "pwa",
    "tensorflow",
    "machine-learning",
    "mexico",
    "open-source"
  ],
  "author": "FalconMX Security",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Falconmx1/mx_falconmx_security"
  },
  "bugs": {
    "url": "https://github.com/Falconmx1/mx_falconmx_security/issues"
  },
  "homepage": "https://falconmx1.github.io/mx_falconmx_security",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "sqlite3": "^5.1.6",
    "pdfkit": "^0.14.0",
    "dotenv": "^16.3.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1",
    "axios": "^1.6.2",
    "node-cron": "^3.0.3",
    "redis": "^4.6.8",
    "bull": "^4.11.5",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "nodemailer": "^6.9.7",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "connect-redis": "^7.0.1",
    "csurf": "^1.11.0",
    "xss": "^1.0.14",
    "dompurify": "^3.0.6",
    "jsdom": "^23.0.1",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.5.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "clean-css-cli": "^5.6.3",
    "uglify-js": "^3.17.4",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "snyk": "^1.1280.0",
    "pm2": "^5.3.0",
    "cross-env": "^7.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "optionalDependencies": {
    "@tensorflow/tfjs-node": "^4.15.0",
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3",
    "sharp": "^0.33.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
      "server.js",
      "workers/*.js",
      "routes/*.js",
      "middleware/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "workers/",
      "routes/",
      "middleware/",
      "public/"
    ],
    "ext": "js,json,html,css",
    "ignore": [
      "data/*.db",
      "logs/*.log",
      "node_modules/"
    ],
    "env": {
      "NODE_ENV": "development",
      "PORT": 3000
    },
    "delay": 1000,
    "events": {
      "start": "echo '🚀 MFH TOOLS PRO - Iniciando servidor...'",
      "restart": "echo '🔄 Reiniciando servidor...'",
      "crash": "echo '💥 Servidor detenido inesperadamente'"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "chrome >= 90",
    "firefox >= 88",
    "safari >= 14",
    "edge >= 90"
  ]
}
